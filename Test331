local function inputRow(y, lTxt, default, onDone)
    local lbl = Instance.new("TextLabel")
    lbl.Parent = Body; lbl.Size = UDim2.new(0.42, 0, 0, 24)
    lbl.Position = UDim2.new(0.04, 0, 0, y)
    lbl.Text = lTxt; lbl.TextColor3 = Color3.fromRGB(175,175,175)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12
    lbl.BackgroundTransparency = 1; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local box = Instance.new("TextBox")
    box.Parent = Body; box.Size = UDim2.new(0.48, 0, 0, 24)
    box.Position = UDim2.new(0.48, 0, 0, y)
    box.Text = tostring(default); box.PlaceholderText = "number"
    box.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
    box.TextColor3 = Color3.fromRGB(0, 215, 255)
    box.Font = Enum.Font.GothamBold; box.TextSize = 13; box.ClearTextOnFocus = true
    Instance.new("UICorner", box)
    box.FocusLost:Connect(function(enter)
        if enter then
            local n = tonumber(box.Text)
            if n then onDone(n) else box.Text = tostring(default) end
        end
    end)
end

local function toggleRow(y, lTxt, onToggle)
    local row = Instance.new("Frame")
    row.Parent = Body; row.Size = UDim2.new(0.92, 0, 0, 24)
    row.Position = UDim2.new(0.04, 0, 0, y); row.BackgroundTransparency = 1
    local lbl = Instance.new("TextLabel")
    lbl.Parent = row; lbl.Size = UDim2.new(0.72, 0, 1, 0)
    lbl.Text = lTxt; lbl.TextColor3 = Color3.fromRGB(200,200,200)
    lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12
    lbl.BackgroundTransparency = 1; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local state = false
    local pill = Instance.new("TextButton")
    pill.Parent = row; pill.Size = UDim2.new(0, 38, 0, 19)
    pill.Position = UDim2.new(1, -40, 0.5, -9)
    pill.BackgroundColor3 = Color3.fromRGB(60, 60, 75); pill.Text = ""
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame")
    knob.Parent = pill; knob.Size = UDim2.new(0, 15, 0, 15)
    knob.Position = UDim2.new(0, 2, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local function vis(on)
        pill.BackgroundColor3 = on and Color3.fromRGB(0,160,255) or Color3.fromRGB(60,60,75)
        knob.Position = on and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,2,0.5,-7)
    end
    pill.MouseButton1Click:Connect(function()
        state = not state; vis(state); onToggle(state)
    end)
    return pill, function(f) state=f; vis(f); onToggle(f) end
end

